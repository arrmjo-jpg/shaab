APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# عناوين الواجهات الأمامية المنفصلة (تُستخدم في روابط البريد مثل إعادة تعيين كلمة المرور)
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alphacms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=alphacms

# نطاقات توصيل الأصول والوسائط (CDN / R2) — راجع config/cdn.php
CDN_ENABLED=false
CDN_URL="${APP_URL}"
MEDIA_URL="${APP_URL}"

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────
# تقوية الإنتاج (Waves 1–3) — اضبط هذه القيم قبل النشر
# ─────────────────────────────────────────────────────────────────────

# CORS — أصول الواجهة الإدارية فقط (لا تستخدم * أبداً)
CORS_ALLOWED_ORIGINS=

# انتهاء صلاحية توكن Sanctum بالدقائق (افتراضي 7 أيام)
SANCTUM_TOKEN_EXPIRATION=10080

# مهلة SMTP بالثواني (يمنع تعلّق الطلب على البريد)
MAIL_TIMEOUT=10

# ─── النسخ الاحتياطي (إلزامي في الإنتاج) ─────────────────────────────
# أقراص الوجهة — أوفسايت إلزامي: s3 أو "local,s3"
BACKUP_DESTINATION_DISKS=local
# كلمة مرور تشفير الأرشيف (سرّ — مدير أسرار)
BACKUP_ARCHIVE_PASSWORD=
# التحقق من سلامة الأرشيف بعد الإنشاء
BACKUP_VERIFY=true
# وجهة تنبيهات النسخ (بريد عمليات حقيقي)
BACKUP_NOTIFICATION_EMAIL=

# ─── مراقبة الصحّة ───────────────────────────────────────────────────
HEALTH_NOTIFICATION_EMAIL=
# توكن سرّي اختياري لمسار نتائج الصحّة (طبقة دفاع إضافية)
HEALTH_SECRET_TOKEN=

# ─── إبطال كاش الواجهة (Next ISR webhook) — إلزامي إنتاجاً ────────────
# يُخطِر واجهة Next بإبطال الوسوم عند نشر/تعديل المحتوى (config/services.php).
# يجب أن يطابق FRONTEND_REVALIDATE_SECRET قيمة REVALIDATE_SECRET في الواجهة.
FRONTEND_REVALIDATE_URL=https://example.com/api/revalidate
FRONTEND_REVALIDATE_SECRET=
FRONTEND_REVALIDATE_TIMEOUT=5

# ─── إخطار محركات البحث (legacy sitemap ping) — اختياري، مُعطَّل افتراضياً ──
# يُخطِر Google + Bing بتحديث الخريطة عند النشر. ⚠️ النقطتان مُهملتان فعلياً (قد تُرجِعان 404).
SEARCH_PING_ENABLED=false

# ─── البحث (Scout / Meilisearch) ────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# ─── أدوات الوسائط ───────────────────────────────────────────────────
# محرّك معالجة الصور (gd افتراضي؛ imagick بديل). ثنائيّات ffmpeg في PATH داخل الصورة.
IMAGE_DRIVER=gd
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# ─── أسرار النشر (docker-compose) — ليست من قراءة Laravel بل تفعيل compose ──
# DB_ROOT_PASSWORD=        # كلمة مرور جذر MySQL (حاوية قاعدة البيانات)
# CLIENT=shaabjo           # العميل المُجمَّع في صورة الواجهة
# API_BASE_URL / SITE_URL / REVALIDATE_SECRET — بيئة حاوية الواجهة
